# =============================================================================
# FinCoach Pro — Environment Variables
# =============================================================================
# HOW TO USE:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in the values below
#   3. Never commit .env to git (it's already in .gitignore)
#
# WHERE TO PLACE .env:
#   → At the project ROOT (same folder as docker-compose.yml)
#     Docker Compose reads it automatically: docker-compose up --build
#
#   → To run WITHOUT Docker (Maven):
#     Export the vars in your terminal before starting:
#       export $(cat .env | xargs) && ./mvnw spring-boot:run
#     Or configure them in your IDE (IntelliJ: Run > Edit Configurations > Env vars)
# =============================================================================


# -----------------------------------------------------------------------------
# JWT — Application token issued after OAuth2 login
# Generate a secure key with: openssl rand -base64 32
# -----------------------------------------------------------------------------
JWT_SECRET=ZmluY29hY2gtcHJvLWp3dC1zZWNyZXQta2V5LWZvci1kZXZlbG9wbWVudA==


# -----------------------------------------------------------------------------
# OpenAI — optional, enables real AI responses in the chat
# Without this, the chat uses pre-written demo responses
# Get your key at: https://platform.openai.com/api-keys
# -----------------------------------------------------------------------------
OPENAI_API_KEY=demo


# -----------------------------------------------------------------------------
# Google OAuth2
# 1. Go to https://console.cloud.google.com
# 2. Create a project > APIs & Services > Credentials > OAuth 2.0 Client ID
# 3. Authorized redirect URI: http://localhost:8080/login/oauth2/code/google
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=


# -----------------------------------------------------------------------------
# Microsoft OAuth2
# 1. Go to https://portal.azure.com > App registrations > New registration
# 2. Supported account types: "Accounts in any organizational directory and personal Microsoft accounts"
# 3. Redirect URI: http://localhost:8080/login/oauth2/code/microsoft
# 4. Go to Certificates & secrets > New client secret
# -----------------------------------------------------------------------------
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=


# -----------------------------------------------------------------------------
# Apple Sign In (requires Apple Developer account — $99/year)
# 1. Go to https://developer.apple.com/account/resources/identifiers/list/serviceId
# 2. Create a Services ID (this is the APPLE_CLIENT_ID)
# 3. Enable "Sign In with Apple", configure domain and redirect URI:
#    http://localhost:8080/login/oauth2/code/apple
# 4. Create a Key at https://developer.apple.com/account/resources/authkeys/list
#    Enable "Sign In with Apple", download the .p8 file
# 5. APPLE_PRIVATE_KEY = full content of the .p8 file on ONE line with \n
#    Example: -----BEGIN PRIVATE KEY-----\nMIGH...\n-----END PRIVATE KEY-----
# -----------------------------------------------------------------------------
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=


# -----------------------------------------------------------------------------
# Frontend URL — used by the backend to redirect after OAuth2 login
# Change this if you deploy to a real domain
# -----------------------------------------------------------------------------
FRONTEND_URL=http://localhost:4200


# -----------------------------------------------------------------------------
# TwelveData API — Real-time stock market data
# Get your key at: https://twelvedata.com/apikey
# Free plan: 8 API credits/minute, 800/day
# -----------------------------------------------------------------------------
TWELVEDATA_API_KEY=
