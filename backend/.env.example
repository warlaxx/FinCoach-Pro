# ─── Database (required) ──────────────────────────────────────────────────────
# Prisma uses DATABASE_URL (PostgreSQL connection string)
DATABASE_URL=postgresql://fincoach:fincoach@localhost:5432/fincoach

# ─── JWT (required) ───────────────────────────────────────────────────────────
# Must be a Base64-encoded 256-bit key.
# Generate one with: openssl rand -base64 32
JWT_SECRET=ZmluY29hY2gtcHJvLWp3dC1zZWNyZXQta2V5LWZvci1kZXZlbG9wbWVudA==

# ─── OpenAI (optional) ────────────────────────────────────────────────────────
# Leave as "demo" to use keyword-matched static responses (no API key needed).
OPENAI_API_KEY=demo

# ─── OAuth2 — Google (optional) ───────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── OAuth2 — Microsoft (optional) ────────────────────────────────────────────
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ─── OAuth2 — Apple (optional) ────────────────────────────────────────────────
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
# Paste the contents of your .p8 file with newlines replaced by \n
APPLE_PRIVATE_KEY=

# ─── Email (optional) ─────────────────────────────────────────────────────────
# Leave blank to have emails logged to the console instead of sent.
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
# SMTP TLS certificate validation is ON by default. Set to "false" ONLY for a
# self-signed/dev SMTP server — never in production.
MAIL_TLS_REJECT_UNAUTHORIZED=true

# ─── URLs ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:4200
BACKEND_URL=http://localhost:8080

# ─── Node ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=8080
